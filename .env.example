# ---- Seraf Technology — environment variables ----
# Copy this file to `.env.local` for local development,
# and add the same variables in Vercel → Project → Settings → Environment Variables.

# Web3Forms access key — makes the quote/contact form actually send email.
# Get a free key at https://web3forms.com (enter the receiving inbox: info@seraftechnology.com).
# While this is empty, the form works in a demo mode (simulated success, nothing is sent).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Cookieless analytics (Plausible). Set to your domain to enable, e.g. seraftechnology.com
# Leave empty to disable analytics entirely (no cookie banner needed).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
